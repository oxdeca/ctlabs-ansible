        "fallbacks": [
          "mistral/mistral-large-latest",
          "openrouter/free",
          "openrouter/google/gemma-4-31b-it:free",
          "openrouter/qwen/qwen3-coder:free",
          "openrouter/x-ai/grok-4.20"
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "tls": {
      "enabled": true,
      "autoGenerate": false,
