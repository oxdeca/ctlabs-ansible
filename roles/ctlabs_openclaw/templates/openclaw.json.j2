{
  "agents": {
    "defaults": {
      "workspace": "{{ ctlabs_openclaw.defaults.config.dir }}/workspace",
      "models": {
        "mistral/mistral-large-latest": {
          "alias": "Mistral"
        },
        "openrouter/auto": {
          "alias": "OpenRouter"
        },
        "openrouter/free": {},
        "openrouter/google/gemma-4-31b-it:free": {},
        "openrouter/qwen/qwen3-coder:free": {},
        "openrouter/x-ai/grok-4.20": {}
