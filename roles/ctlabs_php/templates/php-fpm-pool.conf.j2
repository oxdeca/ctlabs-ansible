; ------------------------------------------------------------------------------
; File       : /etc/php/php-fpm-pool.conf
; Description : PHP-FPM pool configuration
; ------------------------------------------------------------------------------

[www]
user  = {{ ctlabs_php_fpm_user  }}
group = {{ ctlabs_php_fpm_group }}

listen = {{ ctlabs_php.defaults.config[ctg_os_family].socket_dir }}/php-fpm.sock
listen.owner = {{ ctlabs_php_fpm_user  }}
listen.group = {{ ctlabs_php_fpm_group }}
listen.mode = 0660

pm = dynamic
pm.max_children = 50
pm.start_servers = 5
pm.min_spare_servers = 5
pm.max_spare_servers = 35
pm.max_requests = 500

pm.status_path = /status
ping.path = /ping

catch_workers_output = yes

security.limit_extensions = .php .php3 .php4 .php5 .phtml
