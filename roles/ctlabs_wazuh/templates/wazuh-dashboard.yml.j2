# ------------------------------------------------------------------------------
# File        : ctlabs-ansible/roles/ctlabs_wazuh/templates/wazuh-dashboard.yml.j2
# Description : /etc/wazuh-dashboard/opensearch_dashboards.yml template
# ------------------------------------------------------------------------------

server.host: {{ ctlabs_wazuh_dashboard_host | default(ctlabs_wazuh.defaults.config.dashboard.host) }}
server.port: {{ ctlabs_wazuh.defaults.config.dashboard.port }}

opensearch.hosts:
  - https://{{ ctlabs_wazuh_indexer_network_host | default(ctlabs_wazuh.defaults.config.indexer.network.host) }}:{{ ctlabs_wazuh.defaults.config.indexer.ports.http }}

opensearch.ssl.verificationMode: certificate
opensearch.ssl.certificateAuthorities:
  - /etc/wazuh-indexer/certs/root-ca.pem
opensearch.ssl.certificate: /etc/wazuh-indexer/certs/dashboard.pem
opensearch.ssl.key: /etc/wazuh-indexer/certs/dashboard-key.pem

opensearch.username: kibanaserver
opensearch.password: kibanaserver

server.ssl.enabled: true
server.ssl.certificate: /etc/wazuh-indexer/certs/dashboard.pem
server.ssl.key: /etc/wazuh-indexer/certs/dashboard-key.pem

opensearch.requestHeadersAllowlist: ["securitytenant","Authorization"]

opensearch_security.multitenancy.enabled: true
opensearch_security.multitenancy.tenants.preferred: ["Private", "Global"]
opensearch_security.readonly_mode.roles: ["kibana_read_only"]

uiSettings.overrides.defaultRoute: /app/wazuh-dashboard

server.basePath: /wazuh
server.rewriteBasePath: true
