#{# /etc/openvpn/client/client.conf #}

dev          tun
persist-tun 

proto        udp
ifconfig     {{ ctg_facts.ctlabs_openvpn.client_ip }} {{ ctg_facts.ctlabs_openvpn.server_ip }}
remote       {{ ctg_facts.ctlabs_openvpn.remote }}

secret       ovpn.key
auth         SHA512
auth-nocache

cipher       AES-256-CBC
keepalive    10 60 
verb         3
