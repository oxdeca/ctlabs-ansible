{# ---------------------------------------------------------------------------#}
{# File        : ctlabs-ansible/roles/ctlabs_openarchiver/templates/         #}
{#               openarchiver.env.j2                                         #}
{# Description : OpenArchiver environment variables                          #}
{# ------------------------------------------------------------------------- #}

# --- Application Settings ---
NODE_ENV=production
PORT_BACKEND={{ ctlabs_openarchiver.defaults.config.app.port_backend }}
PORT_FRONTEND={{ ctlabs_openarchiver.defaults.config.app.port_frontend }}
APP_URL={{ ctlabs_openarchiver.defaults.config.app.url }}
ORIGIN={{ ctlabs_openarchiver.defaults.config.app.url }}
BODY_SIZE_LIMIT={{ ctlabs_openarchiver.defaults.config.storage.body_size_limit }}
SYNC_FREQUENCY=* * * * *
ALL_INCLUSIVE_ARCHIVE=false
INGESTION_WORKER_CONCURRENCY=5

# --- PostgreSQL ---
POSTGRES_DB={{ ctlabs_openarchiver.defaults.config.db.name }}
POSTGRES_USER={{ ctlabs_openarchiver.defaults.config.db.user }}
POSTGRES_PASSWORD={{ ctlabs_openarchiver.defaults.config.db.pass }}
DATABASE_URL=postgresql://{{ ctlabs_openarchiver.defaults.config.db.user }}:{{ ctlabs_openarchiver.defaults.config.db.pass }}@{{ ctlabs_openarchiver.defaults.config.db.host }}:{{ ctlabs_openarchiver.defaults.config.db.port }}/{{ ctlabs_openarchiver.defaults.config.db.name }}

# --- Meilisearch ---
MEILI_MASTER_KEY={{ ctlabs_openarchiver.defaults.config.meilisearch.key }}
MEILI_HOST={{ ctlabs_openarchiver.defaults.config.meilisearch.host }}
MEILI_INDEXING_BATCH=500

# --- Redis (Valkey) ---
REDIS_HOST={{ ctlabs_openarchiver.defaults.config.redis.host }}
REDIS_PORT={{ ctlabs_openarchiver.defaults.config.redis.port }}
REDIS_PASSWORD={{ ctlabs_openarchiver.defaults.config.redis.password }}
REDIS_TLS_ENABLED={{ 'true' if ctlabs_openarchiver.defaults.config.redis.tls else 'false' }}

# --- Storage ---
STORAGE_TYPE={{ ctlabs_openarchiver.defaults.config.storage.type }}
STORAGE_LOCAL_ROOT_PATH={{ ctlabs_openarchiver.defaults.config.storage.dir }}
STORAGE_ENCRYPTION_KEY={{ ctlabs_openarchiver.defaults.config.storage.encryption_key }}

# --- Tika ---
TIKA_URL={{ ctlabs_openarchiver.defaults.config.tika.url }}

# --- Security ---
ENABLE_DELETION=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
JWT_SECRET={{ ctlabs_openarchiver.defaults.config.jwt.secret }}
JWT_EXPIRES_IN={{ ctlabs_openarchiver.defaults.config.jwt.expires_in }}
ENCRYPTION_KEY={{ ctlabs_openarchiver.defaults.config.encryption.key }}
