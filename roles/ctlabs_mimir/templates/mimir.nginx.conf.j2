# -----------------------------------------------------------------------------
# File     : /etc/nginx/nginx.conf
# Template : mimir.nginx.conf.j2
# -----------------------------------------------------------------------------

user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log;
pid /run/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include             /etc/nginx/mime.types;
    default_type        application/octet-stream;

    # Your configuration goes here
    server {
        listen 80;
        server_name mimir.ctlabs.internal;
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl;
        server_name mimir.ctlabs.internal;

        ssl_certificate           /etc/ca-ctlabs/mimir.ctlabs.internal.crt;
        ssl_certificate_key       /etc/ca-ctlabs/mimir.ctlabs.internal.prv;

        location /alertmanager {
            proxy_pass https://mimir.ctlabs.internal:9009/alertmanager;
            proxy_ssl_certificate         /etc/ca-ctlabs/mimir.ctlabs.internal.crt;
            proxy_ssl_certificate_key     /etc/ca-ctlabs/mimir.ctlabs.internal.prv;
            proxy_ssl_trusted_certificate /etc/ca-ctlabs/ca-ctlabs.crt;
            proxy_ssl_verify              on;

            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }
}
