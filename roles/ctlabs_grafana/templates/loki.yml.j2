---

# -----------------------------------------------------------------------------
# File : ctlabs-ansible/roles/ctlabs_grafana/templates/loki.yml.j2
# Desc : adding loki as datasource
# -----------------------------------------------------------------------------

apiVersion: 1

datasources:
  - name: Loki
    type: loki
    url : "{{ ctlabs_grafana_loki_url }}"
    access: proxy
    jsonData:
      tlsAuth: true
      tlsAuthWithCACert: true
    secureJsonData:
      tlsClientCert: "$__file{ {{ ctlabs_grafana.defaults.config.server.cert }} }"
      tlsClientKey : "$__file{ {{ ctlabs_grafana.defaults.config.server.key }} }"
      tlsCACert    : "$__file{ {{ ctlabs_grafana.defaults.config.server.ca }} }"
