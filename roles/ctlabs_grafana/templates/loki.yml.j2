---

# -----------------------------------------------------------------------------
# File : ctlabs-ansible/roles/ctlabs_grafana/templates/loki.yml.j2
# Desc : adding loki as datasource
# -----------------------------------------------------------------------------

apiVersion: 1

datasources:
  - name: Loki
    type: loki
    url : "{{ ctlabs_grafana_loki_url }}"
    access: proxy
    jsonData:
      tlsAuth: true
      tlsAuthWithCACert: true
      clientCertFile: {{ ctlabs_grafana.defaults.config.server.cert }}
      clientKeyFile : {{ ctlabs_grafana.defaults.config.server.key }}
      caCertFile    : {{ ctlabs_grafana.defaults.config.server.ca }}
