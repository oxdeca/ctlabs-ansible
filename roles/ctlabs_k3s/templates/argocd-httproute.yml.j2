---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: argocd-server
  namespace: argo
spec:
  parentRefs:
    - name: traefik-gateway
      namespace: kube-system
      sectionName: web
    - name: traefik-gateway
      namespace: kube-system
      sectionName: websecure
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: argocd-server
          port: 80
