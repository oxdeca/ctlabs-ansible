---

# -------------------------------------------------------------------------------------------------
# File        : ctlabs-ansible/roles/ctlabs_blackbox_exporter/templates/blackbox_exporter.conf.j2
# Description : blackbox_exporter web server configuration
# -------------------------------------------------------------------------------------------------

tls_server_config:
  cert_file       : {{ ctlabs_blackbox_exporter.defaults.config.server.tls.crt }}
  key_file        : {{ ctlabs_blackbox_exporter.defaults.config.server.tls.key }}
{% if ctlabs_blackbox_exporter_mtls_client == true %}
  client_ca_file  : {{ ctlabs_blackbox_exporter.defaults.config.server.tls.ca }} 
  client_auth_type: RequireAndVerifyClientCert
{% endif %}
